### ========================================
### LOGIN
### ========================================
# @name login
POST {{authUrl}}/login
Content-Type: {{contentType}}

{
  "nama": "Driver Andi",
  "password": "123456"
}

### ========================================
### CHECK SESSION (ME)
### ========================================
GET {{authUrl}}/me
Content-Type: {{contentType}}
# Cookie: {{login.response.headers.Set-Cookie}}

